# Dev reference only. In prod, APP_ENV!=dev so this file is ignored and values
# come from the runtime environment / Google Cloud Secret Manager.

# Environment: dev (reads this .env) | prod (ignores .env)
APP_ENV=dev
LOG_LEVEL=INFO
LOG_DIR=logs

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=fergon
MYSQL_PASSWORD=fergon
MYSQL_DB=fergon

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Session / JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
DEFAULT_USER_ROLE=teacher
